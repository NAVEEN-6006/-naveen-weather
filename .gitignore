# ─────────────────────────────────────────
# Naveen Weather — .gitignore
# Files and folders Git should NOT track
# ─────────────────────────────────────────

# OS generated files (Mac)
.DS_Store
.AppleDouble
.LSOverride

# Editor folders
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Environment / Secret files
# NEVER commit API keys!
.env
.env.local
.env.production

# Logs
*.log
logs/

# Dependency folders (if we add Node tools later)
node_modules/

# Build output (if added later)
dist/
build/
